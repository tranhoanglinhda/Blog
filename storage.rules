rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Ảnh bài viết: ai cũng xem được, chỉ admin (đã đăng nhập) được tải lên
    match /images/{file} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Chặn mọi đường dẫn khác
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
